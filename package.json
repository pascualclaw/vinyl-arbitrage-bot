{
  "name": "vinyl-arbitrage-bot",
  "version": "1.0.0",
  "description": "Monitor eBay and Discogs for underpriced vinyl records and alert via WhatsApp",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.9.3"
  }
}
