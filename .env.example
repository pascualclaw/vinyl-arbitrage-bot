# ───────────────────────────────────────────────
# eBay Developer API
# Get credentials at: https://developer.ebay.com/
# ───────────────────────────────────────────────
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# ───────────────────────────────────────────────
# Discogs API
# Get your token at: https://www.discogs.com/settings/developers
# ───────────────────────────────────────────────
DISCOGS_TOKEN=

# ───────────────────────────────────────────────
# OpenClaw Gateway
# Already filled in for Docker (host.docker.internal)
# For local dev, use 127.0.0.1
# ───────────────────────────────────────────────
OPENCLAW_GATEWAY_URL=http://host.docker.internal:16862
OPENCLAW_GATEWAY_TOKEN=832bb3640279ac11d7b4ed0f0293984186fdf355442180ab

# ───────────────────────────────────────────────
# Alert target (WhatsApp number with country code)
# ───────────────────────────────────────────────
ALERT_WHATSAPP_NUMBER=+17862708405

# ───────────────────────────────────────────────
# Tuning parameters
# ───────────────────────────────────────────────

# How often to poll, in milliseconds (default: 25 minutes)
POLL_INTERVAL_MS=1500000

# Minimum (Discogs median / total cost) ratio to trigger an alert
SPREAD_THRESHOLD=3.0

# Minimum number of Discogs active listings for a release (liquidity check)
MIN_DISCOGS_SALES=5

# Minimum listing price in USD (skip anything cheaper)
MIN_LISTING_PRICE=25

# Minimum eBay seller feedback percentage required
EBAY_MIN_SELLER_FEEDBACK=95
